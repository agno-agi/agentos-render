# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# JWT verification for AgentOS. Generate your JWT_VERIFICATION_KEY at os.agno.com.
# In production (RUNTIME_ENV != dev), the app refuses to serve traffic without
# JWT_VERIFICATION_KEY or JWT_JWKS_FILE. Local dev (RUNTIME_ENV=dev) is ok without it.
# Set `authorization=False` in app/main.py to opt out (not recommended).
# ---------------------------------------------------------------------------
# Quote the value so every parser (docker compose env_file included) reads
# the multi-line PEM as one variable:
# JWT_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkq...
# -----END PUBLIC KEY-----"
# JWT_JWKS_FILE=/app/jwks.json

# ---------------------------------------------------------------------------
# AgentOS URL. Defaults to http://127.0.0.1:8000 for local development.
# When AgentOS is deployed to a different domain, set this to the public URL.
# ---------------------------------------------------------------------------
# AGENTOS_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# WebSearch Agent uses Parallel SDK when authenticated,
# and falls back to Parallel's keyless MCP server for local development.
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Schedules
# ---------------------------------------------------------------------------
# ENABLE_DEPLOY_CHECK=True
# ENABLE_SCHEDULED_EVALS=False
# EVALS_TAG=smoke
# EVALS_CASE_TIMEOUT_SECONDS=90
# EVALS_SUITE_TIMEOUT_SECONDS=900

# ---------------------------------------------------------------------------
# Slack — set both to enable the Slack interface.
#   SLACK_BOT_TOKEN       Bot User OAuth Token (xoxb-***)
#   SLACK_SIGNING_SECRET  Signing Secret (Basic Information → App Credentials)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg
